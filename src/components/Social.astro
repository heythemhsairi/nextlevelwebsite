---
import { site, whatsappLink } from '../config';
interface Props { footer?: boolean; }
const { footer = false } = Astro.props;

const links = [
  { key: 'instagram', href: site.socials.instagram, label: 'Instagram',
    path: 'M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 4.38a5.3 5.3 0 1 0 0 10.6 5.3 5.3 0 0 0 0-10.6zm0 1.62a3.68 3.68 0 1 1 0 7.36 3.68 3.68 0 0 1 0-7.36zm5.5-1.62a1.24 1.24 0 1 1-2.48 0 1.24 1.24 0 0 1 2.48 0z' },
  { key: 'tiktok', href: site.socials.tiktok, label: 'TikTok',
    path: 'M16.6 5.82a4.28 4.28 0 0 1-1.06-2.82h-3.2v12.9a2.58 2.58 0 1 1-2.58-2.58c.27 0 .53.04.78.12V8.1a5.86 5.86 0 0 0-.78-.05A5.78 5.78 0 1 0 15.54 14V8.36a7.43 7.43 0 0 0 4.36 1.4V6.6a4.28 4.28 0 0 1-3.3-.78z' },
  { key: 'youtube', href: site.socials.youtube, label: 'YouTube',
    path: 'M23 7.3a3 3 0 0 0-2.1-2.1C19 4.7 12 4.7 12 4.7s-7 0-8.9.5A3 3 0 0 0 1 7.3 31 31 0 0 0 .5 12 31 31 0 0 0 1 16.7a3 3 0 0 0 2.1 2.1c1.9.5 8.9.5 8.9.5s7 0 8.9-.5a3 3 0 0 0 2.1-2.1 31 31 0 0 0 .5-4.7 31 31 0 0 0-.5-4.7zM9.8 15.3V8.7l5.7 3.3z' },
  { key: 'whatsapp', href: whatsappLink(), label: 'WhatsApp',
    path: 'M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.82 9.82 0 001.523 5.27l-.999 3.648 3.965-1.717zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z' },
];
const shown = footer ? links.filter((l) => l.key !== 'whatsapp') : links;
---
<div class={footer ? 'social social--footer' : 'social'}>
  {shown.map((l) => (
    <a href={l.href} target="_blank" rel="noopener" class="sbtn" aria-label={l.label}>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d={l.path} /></svg>
    </a>
  ))}
</div>

<style>
  .social { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .sbtn {
    width: 52px; height: 52px; display: grid; place-items: center; border-radius: 16px;
    border: 1px solid var(--line-2); background: rgba(255,255,255,.04); transition: .3s var(--ease);
  }
  .sbtn:hover {
    border-color: var(--red);
    background: linear-gradient(135deg, var(--red), var(--red-deep));
    transform: translateY(-4px); box-shadow: 0 14px 30px -10px rgba(255,42,42,.8);
  }
  .sbtn svg { width: 22px; height: 22px; fill: var(--white); transition: fill .25s; }
  .sbtn:hover svg { fill: #fff; }
  .social--footer .sbtn { width: 44px; height: 44px; border-radius: 13px; }
  .social--footer .sbtn svg { width: 18px; height: 18px; }
</style>
