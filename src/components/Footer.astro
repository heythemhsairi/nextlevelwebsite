---
import { site, nav, whatsappLink } from '../config';
import Social from './Social.astro';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="logo">Next<span>Level</span></a>
      <p>عطينا الـ footage.. واحنا نوصلوك للـ <strong>Next Level</strong>.</p>
    </div>

    <nav class="footer__links" aria-label="Footer">
      {nav.map((i) => <a href={i.href}>{i.label}</a>)}
      <a href="/#form">Contact</a>
    </nav>

    <Social footer={true} />
  </div>

  <div class="container footer__bar">
    <small>{site.domain} — All rights reserved {year} ©</small>
    <a href={whatsappLink()} target="_blank" rel="noopener" class="footer__wa">WhatsApp →</a>
  </div>
</footer>

<!-- floating WhatsApp -->
<a href={whatsappLink()} target="_blank" rel="noopener" class="wa" aria-label="WhatsApp">
  <svg viewBox="0 0 24 24" width="28" height="28" fill="#fff" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.82 9.82 0 001.523 5.27l-.999 3.648 3.965-1.717zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
</a>

<style>
  .footer { border-top: 1px solid var(--line); background: var(--surface); padding-top: 64px; position: relative; overflow: hidden; }
  .footer::before {
    content: ''; position: absolute; inset-inline: 0; top: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--red), transparent); opacity: .6;
  }
  .footer__inner {
    display: grid; grid-template-columns: 1.4fr 1fr auto; gap: 40px; align-items: start;
    padding-bottom: 40px; border-bottom: 1px solid var(--line);
  }
  .footer .logo {
    font-family: var(--font-display); font-weight: 800; font-size: 32px; letter-spacing: -.02em;
    direction: ltr; unicode-bidi: isolate;
  }
  .footer .logo span { color: var(--red); }
  .footer__brand p { color: var(--dim); margin-top: 14px; max-width: 36ch; }
  .footer__links { display: flex; flex-direction: column; gap: 10px; }
  .footer__links a { color: var(--dim); font-weight: 600; font-size: 14px; transition: color .2s; }
  .footer__links a:hover { color: var(--red); }
  .footer__bar { display: flex; justify-content: space-between; align-items: center; padding-block: 22px; flex-wrap: wrap; gap: 10px; }
  .footer__bar small { color: var(--dim-2); font-size: 12.5px; }
  .footer__wa { color: var(--whatsapp); font-weight: 700; font-size: 13px; }

  .wa {
    position: fixed; bottom: 24px; inset-inline-start: 24px; width: 58px; height: 58px;
    background: var(--whatsapp); display: grid; place-items: center; z-index: 60;
    box-shadow: 0 10px 34px rgba(37,211,102,.45); transition: transform .25s var(--ease); border-radius: 50%;
  }
  .wa:hover { transform: scale(1.08); }

  @media (max-width: 760px) {
    .footer__inner { grid-template-columns: 1fr; gap: 28px; justify-items: start; }
  }
</style>
