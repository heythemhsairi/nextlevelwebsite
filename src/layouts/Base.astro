---
import '../styles/global.css';
import { site } from '../config';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Next Level — الـ Team متاع المونتاج متاعك',
  description = 'Next Level — الفريق متاع المونتاج اللي يخليك تـ post كل أسبوع بـ system ثابت. إنت صوّر، واحنا نوصلوك للـ Next Level.',
} = Astro.props;

const origin = (Astro.site ?? new URL('https://nextlevel.tn')).origin;
const canonical = new URL(Astro.url.pathname, origin).href;
const ogImage = new URL('/og.png', origin).href;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: origin,
  description,
  sameAs: [site.socials.instagram, site.socials.tiktok, site.socials.youtube],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    url: `https://wa.me/${site.whatsapp}`,
    areaServed: 'TN',
  },
};
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph / social sharing -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={site.name} />
  <meta property="og:locale" content="ar_TN" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="theme-color" content="#050505" />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Cairo:wght@400;700;900&family=Inter:wght@400;600;700&display=swap"
    rel="stylesheet"
  />

  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
</head>
<body>
  <div class="progress" id="progress"></div>
  <slot />
  <script src="/site.js" is:inline defer></script>
</body>
</html>
