---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Social from '../components/Social.astro';
import Modal from '../components/Modal.astro';
import {
  site, hero, metrics, problems, compare, steps, work,
  testimonials, packs, faqs, socialThumbs, heroPoster, beforeAfter,
} from '../config';

// alternate the live-grid tiles between the two short-form platforms
const nets = ['instagram', 'tiktok'];
const socialCells = socialThumbs.map((thumb, i) => ({
  net: nets[i % 2],
  href: i % 2 === 0 ? site.socials.instagram : site.socials.tiktok,
  thumb,
}));
---
<Base>
  <Nav current="/" />

  <!-- ================= HERO ================= -->
  <section class="hero" id="hero">
    <div class="container hero__inner reveal">
      <div class="hero__text">
        <span class="eyebrow">{hero.badge}</span>
        <h1 class="hero__title">
          الـ <span class="grad">Content</span> متاعك،<br />
          نوصلوه للـ <span class="grad">Next&nbsp;Level</span>
        </h1>
        <p class="lead hero__sub">{hero.sub}</p>
        <div class="hero__cta">
          <a href="#form" class="btn btn--solid btn--lg">{hero.primaryCta} <span class="arrow">←</span></a>
          <a href="#packs" class="btn btn--ghost btn--lg">{hero.secondaryCta}</a>
        </div>
      </div>

      <div class="hero__media">
        <div class="hero__video" role="button" tabindex="0" aria-label="شغّل الـ Showreel"
             data-video="Next Level — Showreel" data-desc="هنا يتحط الـ showreel الحقيقي متاعكم.">
          <img class="hero__poster" src={heroPoster} alt="" loading="eager" width="720" height="960" />
          <span class="hero__videolabel latin">Showreel</span>
          <span class="play" aria-hidden="true"><span></span></span>
        </div>
      </div>
    </div>

    <!-- big editorial metric strip -->
    <div class="container reveal">
      <div class="metrics">
        {metrics.map((m) => (
          <div class="metric">
            <b class="latin" data-count={m.value ?? ''} data-prefix={m.prefix ?? ''}>
              {m.display ?? (m.prefix ?? '') + '0'}
            </b>
            <span>{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= PROBLEM ================= -->
  <section class="section section--line">
    <div class="container reveal">
      <p class="eyebrow">المشكلة الصحيحة</p>
      <h2 class="section__title">
        موش الـ <span class="latin grad">Budget</span><br />
        الـ <span class="latin accent">Consistency</span> هي المشكلة
      </h2>
      <p class="lead" style="margin-top:24px">أغلب الـ brands عندهم فيديو وحدة نجحت… وبعدها سكوت. النجاح يجي من النظام، موش من ضربة الزهر.</p>

      <div class="grid-3">
        {problems.map((p, i) => (
          <article class="card">
            <span class="card__n latin">0{i + 1}</span>
            <h3 class="latin">{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= SYSTEM (compare) ================= -->
  <section class="section section--alt">
    <div class="container reveal">
      <p class="eyebrow">كيفاش نخدمو احنا</p>
      <h2 class="section__title">الفرق هو الـ <span class="accent latin">System</span></h2>
      <p class="lead" style="margin-top:24px">ماهوش شكون يعمل المونتاج — الفرق هو الـ system ورا الـ content. team ثابت، عندو process، يعرف الـ brand متاعك ويخدم معاك على المدى الطويل.</p>

      <div class="compare">
        <div class="compare__col compare__col--bad">
          <span class="compare__tag">{compare.bad.tag}</span>
          <ul>{compare.bad.items.map((t) => <li><i>✗</i>{t}</li>)}</ul>
        </div>
        <div class="compare__vs latin">VS</div>
        <div class="compare__col compare__col--good">
          <span class="compare__tag compare__tag--accent">{compare.good.tag}</span>
          <ul>{compare.good.items.map((t) => <li><i>✓</i>{t}</li>)}</ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= PROCESS ================= -->
  <section class="section section--line">
    <div class="container reveal">
      <p class="eyebrow">من الـ Raw Footage للـ Creatives</p>
      <h2 class="section__title">4 خطوات و فيديوهاتك <span class="accent">حاضرة</span></h2>
      <div class="steps">
        {steps.map((s) => (
          <div class="step">
            <span class="step__n latin">{s.n}</span>
            <h4 class="latin">{s.title}</h4>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= WORK ================= -->
  <section class="section section--alt" id="work">
    <div class="container reveal">
      <p class="eyebrow">الأعمال</p>
      <h2 class="section__title">شويا من الخدمة <span class="accent">متاعنا</span></h2>
      <p class="lead" style="margin-top:24px">كل فيديو عندو goal — engagement، sales، ولا brand awareness.</p>

      <!-- before / after -->
      <div class="ba-wrap">
        <div class="ba" role="slider" tabindex="0" aria-label="مقارنة قبل و بعد المونتاج"
             aria-valuemin="0" aria-valuemax="100" aria-valuenow="50">
          <div class="ba__layer ba__after">
            <img src={beforeAfter.after} alt="بعد المونتاج — color grading و edit" width="1280" height="720" />
          </div>
          <div class="ba__layer ba__before">
            <img src={beforeAfter.before} alt="قبل المونتاج — raw footage" width="1280" height="720" />
          </div>
          <span class="ba__tag ba__tag--b latin">Before</span>
          <span class="ba__tag ba__tag--a latin">After</span>
          <div class="ba__handle"><div class="ba__grip" aria-hidden="true">⟷</div></div>
        </div>
        <p class="ba__hint">اسحب ⟷ ولا استعمل أسهم الكيبورد باش تشوف الفرق</p>
      </div>

      <div class="gallery">
        {work.map((w) => (
          <figure class="shot" role="button" tabindex="0" aria-label={`شوف فيديو ${w.tag}`}
                  data-video={w.tag} data-desc={`فيديو ${w.tag}.`}>
            <div class="shot__media">
              <video src={w.video} poster={w.poster} muted loop playsinline preload="none"></video>
              <div class="shot__play" aria-hidden="true"><span></span></div>
            </div>
            <figcaption><span class="tag latin">{w.tag}</span> {w.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= PROOF ================= -->
  <section class="section section--line">
    <div class="container reveal">
      <p class="eyebrow">Social Proof</p>
      <h2 class="section__title">شنوا قالو الـ <span class="accent latin">Clients</span> متاعنا</h2>
      <p class="lead" style="margin-top:24px">مش احنا نقولو — خليهم يحكيو.</p>
      <div class="grid-3">
        {testimonials.map((t) => (
          <div class="testi" role="button" tabindex="0" aria-label={`شوف شهادة ${t.name}`}
               data-video={t.name} data-desc={`شهادة ${t.name} على Next Level.`}>
            <div class="testi__video">
              <img class="testi__poster" src={t.poster} alt="" width="640" height="480" loading="lazy" />
              <span class="play play--sm" aria-hidden="true"><span></span></span>
              <span class="testi__watch latin">▶ Watch Testimonial</span>
            </div>
            <div class="testi__foot">
              <div><b class="latin">{t.name}</b><small>{t.role}</small></div>
              <span class="stars" role="img" aria-label="تقييم 5 من 5">★★★★★</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= SOCIAL STRIP ================= -->
  <section class="section section--alt">
    <div class="container reveal" style="text-align:center">
      <p class="eyebrow" style="justify-content:center">On Social</p>
      <h2 class="section__title">شوف الـ <span class="accent latin">Content</span> متاعنا live</h2>
      <p class="lead" style="margin:24px auto 0">نخدمو كل يوم — تبّعنا و شوف بعينك.</p>
      <div class="social-grid">
        {socialCells.map((c) => (
          <a class="social-cell" href={c.href} target="_blank" rel="noopener"
             aria-label={`شوف الـ content متاعنا على ${c.net}`}>
            <img src={c.thumb} alt="" width="400" height="400" loading="lazy" />
          </a>
        ))}
      </div>
      <div style="margin-top:34px"><Social /></div>
    </div>
  </section>

  <!-- ================= PRICING ================= -->
  <section class="section section--line" id="packs">
    <div class="container reveal">
      <p class="eyebrow">Packs</p>
      <h2 class="section__title">اختار الـ <span class="accent latin">Pack</span> اللي يواتيك</h2>
      <p class="lead" style="margin-top:24px">تبدا صغير ولا تـ scale — كيفما تحب، احنا معاك.</p>

      <div class="pricing">
        {packs.map((p) => (
          <div class={`plan ${p.popular ? 'plan--popular' : ''}`}>
            {p.popular && <span class="plan__ribbon latin">★ MOST POPULAR</span>}
            <span class="plan__kicker latin">{p.kicker}</span>
            <h3 class="plan__name latin">{p.name}</h3>
            <p class="plan__from">Starting from</p>
            <div class="plan__price latin">{p.price}</div>
            <ul class="plan__feats">
              {p.feats.map((f) => <li><i>✓</i>{f}</li>)}
            </ul>
            <a href="#form" class={`btn ${p.popular ? 'btn--solid' : 'btn--ghost'} plan__cta`}>{p.cta} ←</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= CTA BAND ================= -->
  <section class="ctaband">
    <div class="container reveal">
      <h2 class="ctaband__title">فاش <span class="accent">تستنا</span>؟</h2>
      <p class="lead" style="margin:18px auto 0">الـ brands اللي تنجح في الـ ads مش عندهم budget أكبر — عندهم creative أحسن و system ثابت.</p>
      <a href="#form" class="btn btn--solid btn--lg" style="margin-top:30px">ابدأ اليوم ←</a>
    </div>
  </section>

  <!-- ================= FAQ ================= -->
  <section class="section section--line" id="faq">
    <div class="container reveal">
      <h2 class="section__title" style="text-align:center">عندك <span class="accent">سؤال</span>؟</h2>
      <div class="faq">
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}<i>+</i></summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= FORM ================= -->
  <section class="section section--alt" id="form">
    <div class="container reveal form-wrap">
      <span class="eyebrow" style="justify-content:center">Book a Call</span>
      <h2 class="section__title">ابدأ <span class="accent">توة</span></h2>
      <p class="lead" style="margin:18px auto 0">عمّر الـ form ونكلموك في أقل من <strong>24 ساعة</strong></p>

      <form class="form" id="leadForm" novalidate>
        <label>اسمك ولا اسم البراند
          <input type="text" name="bizname" placeholder="Ex: Ma Boutique TN" required />
        </label>
        <label>نومرو الـ WhatsApp
          <input type="tel" name="phone" placeholder="216XXXXXXXX" required />
        </label>
        <label>نوع البيزنس
          <select name="biztype" required>
            <option value="" disabled selected>اختار الـ Catégorie</option>
            <option>E-commerce</option>
            <option>Personal Brand</option>
            <option>Service / Métier</option>
            <option>Resto / Café</option>
            <option>Autre</option>
          </select>
        </label>
        <div class="form__group">
          <span class="form__legend">وقتاش نكلموك؟</span>
          <div class="pick">
            <input type="radio" name="time" id="t1" data-label="صباح 9h–12h" /><label for="t1">صباح<small>9h – 12h</small></label>
            <input type="radio" name="time" id="t2" data-label="عشية 12h–18h" /><label for="t2">عشية<small>12h – 18h</small></label>
          </div>
        </div>
        <div class="form__group">
          <span class="form__legend">عندك فيديوهات حاضرة باش تتمنتج؟</span>
          <div class="pick">
            <input type="radio" name="ready" id="y" data-label="Yes" /><label for="y">Yes</label>
            <input type="radio" name="ready" id="n" data-label="No" /><label for="n">No</label>
          </div>
        </div>
        <button type="submit" class="btn btn--solid form__submit">نحب نخدم معاكم ←</button>
        <p class="form__ok" id="formOk">تمّت! ✅ توّا يتحلّك الـ WhatsApp بالمعلومات — كمّل الإرسال و احنا نجاوبوك بسرعة.</p>
      </form>
    </div>
  </section>

  <Modal />
  <Footer />
</Base>

<style>
  /* ---------- hero (cinematic video stage) ---------- */
  .hero {
    padding-block: clamp(56px, 9vw, 120px) clamp(40px, 6vw, 80px);
    position: relative; overflow: hidden;
  }
  .hero__inner { display: grid; grid-template-columns: 1.05fr .95fr; gap: 60px; align-items: center; }
  .hero__text { display: flex; flex-direction: column; align-items: flex-start; }
  .hero__title {
    font-family: var(--font-ar); font-weight: 900;
    font-size: clamp(40px, 6.6vw, 88px); line-height: 1.12;
    margin-top: 22px; text-align: right; text-wrap: balance;
  }
  .hero__title .grad { font-family: var(--font-display); font-weight: 800; letter-spacing: -.02em; }
  .hero__sub { margin: 26px 0 0; }
  .hero__cta { display: flex; gap: 14px; margin-top: 34px; flex-wrap: wrap; }

  .hero__media { position: relative; }
  .hero__media::before {
    content: ''; position: absolute; inset: -30px; z-index: 0; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,42,42,.35), transparent 65%); filter: blur(40px);
  }
  .hero__video {
    position: relative; z-index: 1; aspect-ratio: 9/12; border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 50% 35%, rgba(255,42,42,.18), transparent 60%),
      linear-gradient(160deg, #1a1012, #0a0708);
    border: 1px solid var(--line-2); display: grid; place-items: center; cursor: pointer; overflow: hidden;
    box-shadow: 0 40px 90px -30px rgba(255,42,42,.5), inset 0 1px 0 rgba(255,255,255,.05);
    transition: transform .35s var(--ease), box-shadow .35s var(--ease);
  }
  .hero__poster { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;
    opacity: .8; filter: saturate(1.05) contrast(1.02); }
  .hero__video::after {
    content: ''; position: absolute; inset: 0; border-radius: inherit; pointer-events: none; z-index: 1;
    background: linear-gradient(to top, rgba(5,5,5,.7), transparent 55%),
                radial-gradient(circle at 50% 42%, rgba(var(--red-rgb),.18), transparent 55%);
  }
  .hero__video:hover { transform: translateY(-6px); box-shadow: 0 50px 100px -28px rgba(255,42,42,.7); }
  .hero__video:hover .hero__poster { opacity: .95; transform: scale(1.04); transition: transform .6s var(--ease), opacity .4s; }
  .hero__videolabel { position: absolute; top: 18px; inset-inline-start: 20px; z-index: 2;
    font-size: 12px; letter-spacing: .22em; text-transform: uppercase; color: var(--dim); }

  .play {
    width: 88px; height: 88px; border-radius: 50%; border: none; cursor: pointer; z-index: 2; position: relative;
    background: linear-gradient(135deg, var(--red), var(--red-deep)); display: grid; place-items: center;
    box-shadow: 0 0 0 0 rgba(255,42,42,.55); animation: pulse 2.4s infinite;
  }
  .play span { width: 0; height: 0; border-style: solid; border-width: 14px 0 14px 23px;
    border-color: transparent transparent transparent #fff; margin-left: 6px; direction: ltr; }
  .play--sm { width: 60px; height: 60px; animation: none; }
  .play--sm span { border-width: 10px 0 10px 16px; margin-left: 4px; }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(255,42,42,.55); }
    70% { box-shadow: 0 0 0 26px rgba(255,42,42,0); }
    100% { box-shadow: 0 0 0 0 rgba(255,42,42,0); }
  }

  /* metrics + title-latin styling shared in global.css */

  /* ---------- 3-card grid ---------- */
  .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; margin-top: clamp(44px,6vw,68px); }
  .card {
    padding: 38px 32px; border-radius: var(--radius); position: relative; overflow: hidden;
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    border: 1px solid var(--line); transition: transform .35s var(--ease), border-color .35s, box-shadow .35s;
  }
  .card::before { content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1px; opacity: 0;
    background: linear-gradient(135deg, var(--red), transparent 50%); transition: opacity .35s;
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor; mask-composite: exclude; }
  .card:hover { transform: translateY(-6px); border-color: transparent; box-shadow: 0 30px 60px -30px rgba(255,42,42,.5); }
  .card:hover::before { opacity: 1; }
  .card__n { font-family: var(--font-display); font-weight: 800; font-size: 14px; color: var(--red); letter-spacing: .12em; }
  .card h3 { font-family: var(--font-display); font-weight: 700; font-size: 26px; margin: 14px 0 12px; letter-spacing: -.02em; }
  .card p { color: var(--dim); }

  /* ---------- compare ---------- */
  .compare { display: grid; grid-template-columns: 1fr auto 1fr; gap: 18px; align-items: stretch; margin-top: clamp(44px,6vw,68px); }
  .compare__col { padding: 36px 32px; border-radius: var(--radius); background: linear-gradient(180deg, var(--surface-2), var(--surface)); border: 1px solid var(--line); }
  .compare__col--bad { opacity: .9; }
  .compare__col--good { border-color: rgba(255,42,42,.4); background: linear-gradient(180deg, rgba(255,42,42,.07), var(--surface)); box-shadow: 0 30px 60px -34px rgba(255,42,42,.55); }
  .compare__vs { display: grid; place-items: center; font-family: var(--font-display); font-weight: 800; font-size: 22px;
    color: #fff; background: linear-gradient(135deg, var(--red), var(--red-deep)); border-radius: 50%; width: 58px; height: 58px; align-self: center; box-shadow: 0 0 30px -6px rgba(255,42,42,.8); }
  .compare__tag { display: inline-block; font-family: var(--font-display); font-weight: 700; font-size: 12px;
    letter-spacing: .1em; text-transform: uppercase; padding: 6px 14px; border-radius: 999px; background: var(--surface-3); color: var(--dim); margin-bottom: 22px; }
  .compare__tag--accent { background: linear-gradient(135deg, var(--red), var(--red-deep)); color: #fff; }
  .compare__col ul { display: flex; flex-direction: column; gap: 14px; }
  .compare__col li { display: flex; gap: 12px; font-size: 16px; color: var(--dim); }
  .compare__col--good li { color: var(--white); }
  .compare__col li i { font-style: normal; font-weight: 800; }
  .compare__col--bad li i { color: var(--dim-2); }
  .compare__col--good li i { color: var(--red); }

  /* ---------- steps ---------- */
  .steps { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-top: clamp(44px,6vw,68px); }
  .step { padding: 32px 26px; border-radius: var(--radius); background: linear-gradient(180deg, var(--surface-2), var(--surface));
    border: 1px solid var(--line); transition: transform .35s var(--ease), border-color .35s, box-shadow .35s; }
  .step:hover { transform: translateY(-6px); border-color: rgba(255,42,42,.4); box-shadow: 0 28px 56px -32px rgba(255,42,42,.5); }
  .step__n { font-family: var(--font-display); font-weight: 800; font-size: 46px; line-height: 1;
    background: linear-gradient(180deg, var(--red), var(--red-blood)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; display: block; margin-bottom: 16px; }
  .step h4 { font-family: var(--font-display); font-weight: 700; font-size: 18px; margin-bottom: 8px; }
  .step p { color: var(--dim); font-size: 14.5px; }

  /* ---------- before/after ---------- */
  .ba-wrap { max-width: 840px; margin: clamp(44px,6vw,64px) auto 0; }
  .ba { position: relative; aspect-ratio: 16/9; overflow: hidden; cursor: ew-resize; user-select: none;
    border-radius: var(--radius); border: 1px solid var(--line-2); box-shadow: 0 40px 80px -36px rgba(255,42,42,.5); }
  .ba__layer { position: absolute; inset: 0; }
  .ba__layer img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ba__before { clip-path: inset(0 0 0 50%); }
  .ba__before img { filter: contrast(.95); }
  .ba__tag { position: absolute; top: 14px; font-family: var(--font-display); font-weight: 700; font-size: 12px; letter-spacing: .04em; padding: 6px 13px; border-radius: 999px; background: rgba(0,0,0,.6); backdrop-filter: blur(4px); }
  .ba__tag--b { inset-inline-start: 14px; color: var(--dim); }
  .ba__tag--a { inset-inline-end: 14px; color: #fff; background: linear-gradient(135deg, var(--red), var(--red-deep)); }
  .ba__handle { position: absolute; inset-block: 0; left: 50%; width: 3px; background: var(--white); transform: translateX(-50%); z-index: 3; box-shadow: 0 0 16px rgba(255,42,42,.9); }
  .ba__grip { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
    width: 50px; height: 50px; border-radius: 50%; background: linear-gradient(135deg, var(--red), var(--red-deep)); color: #fff; display: grid; place-items: center; font-size: 17px; box-shadow: 0 8px 24px -4px rgba(255,42,42,.9); }
  .ba__hint { text-align: center; color: var(--dim); margin-top: 16px; font-size: 14px; }

  /* ---------- gallery ---------- */
  .gallery { display: grid; grid-template-columns: repeat(5,1fr); gap: 14px; margin-top: clamp(40px,5vw,56px); }
  .shot { border-radius: var(--radius-sm); overflow: hidden; border: 1px solid var(--line); background: var(--surface-2); transition: .35s var(--ease); cursor: pointer; }
  .shot:hover { transform: translateY(-6px); border-color: rgba(255,42,42,.5); box-shadow: 0 24px 50px -28px rgba(255,42,42,.7); }
